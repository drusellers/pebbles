    "fq24": {
      "id": "fq24",
      "title": "abcd",
      "body": "We need a CLI command that lets us edit the title of an issue.\n\n## Implementation\n\nThe functionality already exists via the `pebbles update` command:\n\n```\npebbles update <id> --title \"new title\"\n```\n\n## Log\n- 2026-02-18: Verified `pebbles update --title` already provides this functionality\n- 2026-02-18: Fixed pre-existing clippy warnings across the codebase",
      "status": "done",
      "priority": "medium",
      "parent": null,
      "children": [],
      "dependencies": [],
      "tags": [],
      "created_at": "2026-02-18T21:06:18.410303Z",
      "updated_at": "2026-02-18T22:28:08.567409Z"
    },
    "6vt4": {
      "id": "6vt4",
      "title": "add ls alias to list",
      "body": "## Implementation\n\nAdded `ls` as a visible alias for the `list` command in src/cli.rs.\n\n## Log\n- 2026-02-18: Added `#[command(visible_alias = \"ls\")]` to List variant",
      "status": "done",
      "priority": "medium",
      "parent": null,
      "children": [],
      "dependencies": [],
      "tags": [],
      "created_at": "2026-02-18T22:40:24.940070Z",
